CROSS ?= arm-none-eabi-

###############################################################################
# Directories
###############################################################################

OUT_DIR = out
BIN_DIR = bin

###############################################################################
# Files
###############################################################################

TARGET = blinky_f1x0x4

SRCS = \
	blinky.c \
	systick.c

OBJS = \
	$(OUT_DIR)/blinky.o \
	$(OUT_DIR)/systick.o

###############################################################################
# Toolchain
###############################################################################

CC      = $(CROSS)gcc
LD      = $(CROSS)ld
OBJCOPY = $(CROSS)objcopy

###############################################################################
# Flags
###############################################################################

CFLAGS  += -O3 -Wall -g -std=gnu99
CFLAGS  += -DGD32F1X0
CFLAGS  += -mthumb -mcpu=cortex-m3
CFLAGS  += -msoft-float -mfix-cortex-m3-ldrd
CFLAGS  += $(ARCH_FLAGS)
CFLAGS  += -Ilibopencm3/include/
CFLAGS  += $(EXTRA_CFLAGS)

###############################################################################
# Libraries
###############################################################################

LIBC       = $(shell $(CC) $(CFLAGS) --print-file-name=libc.a)
LIBGCC     = $(shell $(CC) $(CFLAGS) --print-libgcc-file-name)

LIBOPENCM3 = libopencm3/lib/libopencm3_gd32f1x0.a
OPENCM3_MK = lib/gd32/f1x0

###############################################################################
# Linker
###############################################################################

LDPATH            = libopencm3/lib/
LDSCRIPT_F1X0X4   = libopencm3/lib/gd32/f1x0/gd32f1x0x4.ld

LDFLAGS += -L$(LDPATH)
LDFLAGS += --gc-sections
LDFLAGS += -T$(LDSCRIPT_F1X0X4)

LDLIBS += $(LIBOPENCM3)
LDLIBS += $(LIBC)
LDLIBS += $(LIBGCC)

###############################################################################
# Outputs
###############################################################################

ELF = $(BIN_DIR)/$(TARGET).elf
BIN = $(BIN_DIR)/$(TARGET).bin
HEX = $(BIN_DIR)/$(TARGET).hex

###############################################################################
# Build
###############################################################################

all: dirs $(LIBOPENCM3) $(ELF) $(BIN) $(HEX)

dirs:
	mkdir -p $(OUT_DIR)
	mkdir -p $(BIN_DIR)

###############################################################################
# ELF
###############################################################################

$(ELF): $(OBJS) $(LIBOPENCM3)
	$(LD) -o $@ $(LDFLAGS) $(OBJS) $(LDLIBS)

###############################################################################
# BIN
###############################################################################

$(BIN): $(ELF)
	$(OBJCOPY) -S -O binary $< $@

###############################################################################
# HEX
###############################################################################

$(HEX): $(ELF)
	$(OBJCOPY) -S -O ihex $< $@

###############################################################################
# Objects
###############################################################################

$(OUT_DIR)/%.o: %.c
	$(CC) $(CFLAGS) -c $< -o $@

###############################################################################
# libopencm3
###############################################################################

$(LIBOPENCM3):
	CFLAGS="$(CFLAGS)" $(MAKE) -C libopencm3 $(OPENCM3_MK) V=1

###############################################################################
# Flash
###############################################################################

flash: $(ELF)
	pyocd load $(ELF) \
	--target gd32f150g8 \
	--pack ./GD32_FIXED.pack

###############################################################################
# Debug
###############################################################################

debug:
	pyocd commander \
	--target gd32f150g8 \
	--pack ./GD32_FIXED.pack

###############################################################################
# Clean
###############################################################################

.PHONY: clean

clean:
	rm -rf $(OUT_DIR)
	rm -rf $(BIN_DIR)